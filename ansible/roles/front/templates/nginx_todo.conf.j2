server {
    listen 80;
    server_name {{ domain_name }};

    root /var/www/{{ domain_name }};
    index index.html;

    # --- Application Angular (fichiers statiques buildés) ---
    location / {
        try_files $uri $uri/ /index.html;
    }

    # --- Reverse proxy vers l'API Back (Node.js/Express, subnet privé) ---
    location /api/ {
        proxy_pass http://{{ hostvars['back']['ansible_host'] }}:{{ app_back_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

# Une fois Certbot exécuté, un second bloc "server { listen 443 ssl; ... }"
# sera automatiquement ajouté ici par certbot --nginx.